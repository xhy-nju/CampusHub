# CampusHub ignore rules

# OS metadata
.DS_Store
Thumbs.db
desktop.ini

# Editors and IDEs
.idea/
*.iml
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Local environment and secrets
.env
.env.*
!.env.example
!**/.env.example
application-local.yml
application-local.yaml
application-*.local.yml
application-*.local.yaml

# Logs and runtime files
logs/
*.log
*.pid
*.seed
*.tmp
*.temp

# Frontend: Vue / Vite / Node
node_modules/
**/node_modules/
frontend/dist/
frontend/.vite/
frontend/.cache/
frontend/coverage/
frontend/.env.local
frontend/.env.*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Backend: Java / Spring Boot / Maven / Gradle
backend/target/
backend/build/
backend/out/
backend/.gradle/
backend/.mvn/timing.properties
*.class
hs_err_pid*
replay_pid*

# Database dumps and generated data
database/dumps/
database/backups/
*.dump
*.sql.gz
*.sqlite
*.sqlite3
dump.rdb

# Uploaded or generated local assets
uploads/
backend/uploads/
tmp/
